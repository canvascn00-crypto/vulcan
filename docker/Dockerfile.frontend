# === Vulcan Frontend Docker Image ===

FROM node:20-alpine AS vulcan-frontend

WORKDIR /app

# Install deps
COPY vulcan-webui/package*.json ./
RUN npm ci

# Copy source
COPY vulcan-webui/ .

# Build
RUN npm run build

# Production stage
FROM nginx:alpine

COPY --from=vulcan-frontend /app/dist /usr/share/nginx/html
COPY docker/nginx.frontend.conf /etc/nginx/conf.d/default.conf

EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]
