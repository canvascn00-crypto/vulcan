# Vulcan 环境变量
# 路径: ~/.vulcan/.env

# WeChat (iLink Bot API)
# 从 Hermes Agent 继承
ILINK_TOKEN=
WECHAT_HOME_CHAT_ID=

# Telegram
TELEGRAM_BOT_TOKEN=

# Discord
DISCORD_BOT_TOKEN=

# WhatsApp
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Signal
SIGNAL_PHONE_NUMBER=

# Mattermost
MATTERMOST_URL=
MATTERMOST_TOKEN=

# Matrix
MATRIX_HOMESERVER=
MATRIX_TOKEN=
MATRIX_USER_ID=

# DingTalk
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=

# FeiShu
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# WeCom
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_AGENT_ID=

# QQ Bot
QQ_ADAPTER_TYPE=none
QQ_SERVER_URL=http://127.0.0.1:5700

# BlueBubbles
BLUEBUBBLES_URL=
BLUEBUBBLES_PASSWORD=

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Email
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=

# Home Assistant
HA_BASE_URL=
HA_TOKEN=

# Webhook
WEBHOOK_SECRET=

# Model Provider
VULCAN_MODEL_PROVIDER=custom
VULCAN_MODEL_BASE_URL=https://df.dawnloadai.com:9888/v1
VULCAN_MODEL_API_KEY=sk-df2...
VULCAN_MODEL_NAME=GLM-5.1
