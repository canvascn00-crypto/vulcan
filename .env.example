# Vulcan AI — 环境变量配置
# 复制此文件为 .env 并填写实际值

# === 必填 ===
VULCAN_API_KEY=change-me-in-production

# === 数据库 ===
DATABASE_URL=postgresql+asyncpg://vulcan:change_me@localhost:5432/vulcan
REDIS_URL=redis://localhost:6379/0
CHROMA_HOST=localhost
CHROMA_PORT=8000

# === 日志 & 可观测性 ===
LOG_LEVEL=INFO
TRACE_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=

# === 模型提供商 ===
# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com

# 本地 vLLM
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=meta-llama/Llama-3-70b-instruct

# === 微信渠道 (继承 Hermes) ===
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# === 渠道配置 ===
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=

# === 安全 ===
SECRET_KEY=change-me-generate-with-openssl-rand-base64-32
ALLOWED_ORIGINS=http://localhost:3000
